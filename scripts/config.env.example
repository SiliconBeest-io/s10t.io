# =============================================================================
# SiliconBeest — Script Configuration Overrides
#
# Copy this file to config.env and edit to customize resource names.
#
# Usage:
#   cp scripts/config.env.example scripts/config.env
#   # Edit values, then run: ./scripts/sync-config.sh --apply
#
# For GitHub Actions CI, set these as Repository Variables instead.
# =============================================================================

# Master prefix — changes all resource name defaults at once
# PROJECT_PREFIX=myinstance

# ---------------------------------------------------------------------------
# Instance identity
# ---------------------------------------------------------------------------
# INSTANCE_DOMAIN=social.example.com
# INSTANCE_TITLE=My SiliconBeest Instance
# REPOSITORY_URL=https://github.com/SJang1/siliconbeest
# REGISTRATION_MODE=open

# Federation signature verification override. Keep false in production.
# Setting true is an explicit operator choice that skips HTTP signature checks.
# SKIP_SIGNATURE_VERIFICATION=false

# Optional Cloudflare Workers AI features. The binding is omitted unless enabled.
# WORKERS_AI_ENABLED=false
# WORKERS_AI_RECOMMENDATION_MODEL=@cf/baai/bge-m3
# WORKERS_AI_TRANSLATION_MODEL=@cf/meta/m2m100-1.2b
# WORKERS_AI_IMAGE_CAPTION_MODEL=@cf/moondream/moondream3.1-9B-A2B
# Native rate-limit bindings are enabled by default when Workers AI is enabled.
# Limits must be positive integers. Periods must be either 10 or 60 seconds.
# WORKERS_AI_RATE_LIMITS=true
# WORKERS_AI_RECOMMENDATION_RATE_LIMIT=2
# WORKERS_AI_RECOMMENDATION_RATE_LIMIT_PERIOD_SECONDS=60
# WORKERS_AI_TRANSLATION_RATE_LIMIT=6
# WORKERS_AI_TRANSLATION_RATE_LIMIT_PERIOD_SECONDS=60
# WORKERS_AI_IMAGE_DESCRIPTION_RATE_LIMIT=4
# WORKERS_AI_IMAGE_DESCRIPTION_RATE_LIMIT_PERIOD_SECONDS=60
# When rate limits are enabled, namespace IDs must be positive integers and
# pairwise distinct. Use different IDs for preview and production. Namespace
# IDs are not required when WORKERS_AI_RATE_LIMITS=false.
# WORKERS_AI_RECOMMENDATION_RATE_LIMIT_NAMESPACE_ID=1001
# WORKERS_AI_TRANSLATION_RATE_LIMIT_NAMESPACE_ID=1002
# WORKERS_AI_IMAGE_DESCRIPTION_RATE_LIMIT_NAMESPACE_ID=1003

# ---------------------------------------------------------------------------
# Worker name overrides (uncomment to customize)
# ---------------------------------------------------------------------------
# MAIN_WORKER_NAME=myinstance
# CONSUMER_NAME=myinstance-consumer
# EMAIL_SENDER_NAME=myinstance-email

# ---------------------------------------------------------------------------
# Cloudflare resource name overrides (uncomment to customize)
# ---------------------------------------------------------------------------
# D1_DATABASE_NAME=myinstance-db
# R2_BUCKET_NAME=myinstance-media
# KV_CACHE_TITLE=myinstance-cache
# KV_SESSIONS_TITLE=myinstance-sessions
# KV_FEDIFY_TITLE=myinstance-fedify-kv
# QUEUE_FEDERATION=myinstance-federation
# QUEUE_INTERNAL=myinstance-internal
# QUEUE_EMAIL=myinstance-email
# QUEUE_DLQ=myinstance-federation-dlq

# ---------------------------------------------------------------------------
# Cloudflare resource IDs
# Filled automatically by setup.sh, or copy from Cloudflare dashboard.
# When set, sync-config.sh --apply uses these directly (no API calls needed).
# ---------------------------------------------------------------------------
# D1_DATABASE_ID=
# KV_CACHE_ID=
# KV_SESSIONS_ID=
# KV_FEDIFY_ID=
